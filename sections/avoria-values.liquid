<section class="av-values">
  <div class="av-container">
    <div class="av-values-grid">
      {%- for block in section.blocks -%}
        <div class="av-value-item" {{ block.shopify_attributes }}>
          <div class="av-value-icon">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1.5"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'science' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg>
              {%- when 'quality' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              {%- when 'returns' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
            {%- endcase -%}
          </div>
          <div class="av-value-title">{{ block.settings.title }}</div>
          <div class="av-value-desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Avoria Value Props",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "value",
      "name": "Value Prop",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping truck" },
            { "value": "science", "label": "Science / Research" },
            { "value": "quality", "label": "Quality medal" },
            { "value": "returns", "label": "Returns / Clock" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Kostenloser Versand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Ab 25 € Bestellwert versandkostenfrei innerhalb Deutschlands."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avoria Value Props",
      "blocks": [
        { "type": "value", "settings": { "icon": "shipping", "title": "Kostenloser Versand", "description": "Ab 25 € Bestellwert versandkostenfrei innerhalb Deutschlands." } },
        { "type": "value", "settings": { "icon": "science", "title": "Wissenschaftlich fundiert", "description": "Alle Produkte basieren auf aktuellen wissenschaftlichen Erkenntnissen." } },
        { "type": "value", "settings": { "icon": "quality", "title": "Premium Qualität", "description": "Höchste Qualitätsstandards und unabhängige Laboranalysen." } },
        { "type": "value", "settings": { "icon": "returns", "title": "30 Tage Rückgabe", "description": "Nicht überzeugt? 30 Tage Rückgabe ohne Angabe von Gründen." } }
      ]
    }
  ]
}
{% endschema %}
