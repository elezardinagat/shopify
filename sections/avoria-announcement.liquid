{{ 'avoria-custom.css' | asset_url | stylesheet_tag }}

<div class="av-announce">
  <div class="av-announce-inner">
    <div class="av-announce-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1.5"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      {{ section.settings.item_1 }}
    </div>
    <div class="av-announce-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      {{ section.settings.item_2 }}
    </div>
    <div class="av-announce-item">
      <div class="av-announce-stars">
        {%- for i in (1..5) -%}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="gold" stroke="gold" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        {%- endfor -%}
      </div>
      <span class="av-announce-rating-text">{{ section.settings.item_3 }}</span>
    </div>
    <div class="av-announce-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {{ section.settings.item_4 }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Avoria Announcement",
  "settings": [
    {
      "type": "text",
      "id": "item_1",
      "label": "Item 1",
      "default": "Versandkostenfrei ab 25 €"
    },
    {
      "type": "text",
      "id": "item_2",
      "label": "Item 2",
      "default": "Über 300.000 Kunden"
    },
    {
      "type": "text",
      "id": "item_3",
      "label": "Item 3 (Rating)",
      "default": "4.87 / 5 Bewertung"
    },
    {
      "type": "text",
      "id": "item_4",
      "label": "Item 4",
      "default": "Kontakt: +49 800 xxxxxxx"
    }
  ],
  "presets": [
    {
      "name": "Avoria Announcement"
    }
  ]
}
{% endschema %}
