<section class="av-video-section">
  <div class="av-container">
    <div class="av-video-grid">
      {%- for block in section.blocks -%}
        <div class="av-video-card" {{ block.shopify_attributes }}>
          {%- if block.settings.video_url != blank -%}
            <video src="{{ block.settings.video_url }}" poster="{{ block.settings.poster | image_url: width: 600 }}" preload="none" loop playsinline muted></video>
          {%- elsif block.settings.poster != blank -%}
            {{ block.settings.poster | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.label }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          {%- endif -%}
          <div class="av-video-card-overlay">
            <button class="av-play-btn" aria-label="Video abspielen">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="5,3 19,12 5,21"/>
              </svg>
            </button>
          </div>
          <div class="av-video-card-label">
            <span>{{ block.settings.label }}</span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.av-video-card').forEach(function(card) {
    card.addEventListener('click', function() {
      var video = card.querySelector('video');
      if (!video) return;
      if (video.paused) { video.play(); card.querySelector('.av-play-btn').style.opacity = '0'; }
      else { video.pause(); card.querySelector('.av-play-btn').style.opacity = '1'; }
    });
  });
</script>

{% schema %}
{
  "name": "Avoria Video Showcase",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "video",
      "name": "Video Card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Produkt Highlight"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster image"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Avoria Video Showcase",
      "blocks": [
        { "type": "video", "settings": { "label": "Produkt Highlight" } },
        { "type": "video", "settings": { "label": "Brand Story" } },
        { "type": "video", "settings": { "label": "Neue Kollektion" } }
      ]
    }
  ]
}
{% endschema %}
